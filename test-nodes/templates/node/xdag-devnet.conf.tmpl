# Node config
node.ip = {node_host}
node.port = {node_port}
node.tag = {node_tag}
node.maxInboundConnectionsPerIp = 8
node.whiteIPs = {white_ips}
node.generate.block.enable = true

# Node transaction history config
node.transaction.history.enable = false

# HTTP API Config
rpc.http.enabled = true
rpc.http.host = {http_host}
rpc.http.port = {http_port}

# Randomx Config
randomx.flags.fullmem = false
